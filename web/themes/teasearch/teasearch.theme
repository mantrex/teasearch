function teasearch_theme_suggestions_node_alter(array &$suggestions, array $variables)
{
  $node = $variables['elements']['#node'];
  $view_mode = $variables['elements']['#view_mode'];

  if ($view_mode === 'full') {
    $content_type = $node->bundle();

    // Template speciale per about e news
    if (in_array($content_type, ['about'])) {
      $suggestions[] = 'node__info';
      return;
    }
    // Carica lo schema
    $schemas = teasearch_get_detail_schemas();

    // SOLO se esiste schema, suggerisci node__detail
    if (isset($schemas[$content_type])) {
      $suggestions[] = 'node__detail';
    }
  }
}


function teasearch_preprocess_node__info(array &$variables): void
{
  /** @var \Drupal\node\NodeInterface $node */
  $node = $variables['node'];

  // Lingua corrente.
  $language_manager = \Drupal::languageManager();
  $current_language = $language_manager->getCurrentLanguage(LanguageInterface::TYPE_CONTENT)->getId();

  // Assicurati che il nodo sia nella lingua corrente.
  if ($node->hasTranslation($current_language)) {
    $node = $node->getTranslation($current_language);
    $variables['node'] = $node;
  }

  $content_type = $node->bundle();

  // Carica libreria CSS e JS.
  $variables['#attached']['library'][] = 'teasearch/info-page';

  // Content type label (idealmente anche questa funzione deve essere i18n-safe).
  $variables['content_type_label'] = teasearch_get_content_type_label($content_type, $current_language);

  // Immagine header (campo potenzialmente traducibile).
  if ($node->hasField('field_image') && !$node->get('field_image')->isEmpty()) {
    /** @var \Drupal\file\FileInterface|null $image_field */
    $image_field = $node->get('field_image')->first();
    $file = $image_field?->entity;
    if ($file) {
      $variables['header_image_url'] = \Drupal::service('file_url_generator')
        ->generateAbsoluteString($file->getFileUri());
      // Alt viene dalla traduzione del nodo, se il campo è tradotto.
      $variables['header_image_alt'] = $image_field->alt ?? '';
    }
  }

  // Processa i paragraphs del contenuto, forza la traduzione.
  $sections = [];
  if ($node->hasField('field_contents') && !$node->get('field_contents')->isEmpty()) {
    foreach ($node->get('field_contents') as $paragraph_item) {
      /** @var \Drupal\paragraphs\Entity\Paragraph|null $paragraph */
      $paragraph = $paragraph_item->entity;
      if (!$paragraph) {
        continue;
      }

      // Usa la traduzione del paragraph se esiste.
      if ($paragraph->hasTranslation($current_language)) {
        $paragraph = $paragraph->getTranslation($current_language);
      }

      $title = $paragraph->hasField('field_title') && !$paragraph->get('field_title')->isEmpty()
        ? $paragraph->get('field_title')->value
        : '';

      $content = $paragraph->hasField('field_content') && !$paragraph->get('field_content')->isEmpty()
        ? $paragraph->get('field_content')->value
        : '';

      $links = $paragraph->hasField('field_links')
        ? $paragraph->get('field_links')
        : NULL;

      $sections[] = [
        'title'   => $title,
        'content' => $content,
        'links'   => $links,
      ];
    }
  }
  $variables['sections'] = $sections;

  // Carica altri nodi dello stesso content type (escluso quello corrente), filtrati per lingua.
  $other_nodes = [];
  $query = \Drupal::entityQuery('node')
    ->condition('type', $content_type)
    ->condition('nid', $node->id(), '!=')
    ->condition('status', 1)
    ->condition('langcode', $current_language) // considera solo traduzioni nella lingua corrente
    ->accessCheck(TRUE)
    ->sort('title', 'ASC')
    ->range(0, 20);

  $nids = $query->execute();

  if (!empty($nids)) {
    $storage = \Drupal::entityTypeManager()->getStorage('node');
    /** @var \Drupal\node\NodeInterface[] $nodes */
    $nodes = $storage->loadMultiple($nids);

    foreach ($nodes as $other_node) {
      if ($other_node->hasTranslation($current_language)) {
        $other_node = $other_node->getTranslation($current_language);
      }

      $other_nodes[] = [
        'title' => $other_node->label(),
        'url'   => $other_node->toUrl()->toString(),
      ];
    }
  }

  $variables['related_pages'] = $other_nodes;
}



function teasearch_preprocess_node(&$variables)
{
  $node = $variables['node'];
  $view_mode = $variables['view_mode'];

  // Solo per view mode 'full' (pagina di dettaglio)
  if ($view_mode === 'full') {
    $content_type = $node->bundle();

    // Carica lo schema per questo content type
    $schemas = teasearch_get_detail_schemas();

    if (isset($schemas[$content_type])) {
      $schema = $schemas[$content_type];

      // AGGIUNGI QUESTA RIGA: Carica la libreria CSS
      $variables['#attached']['library'][] = 'teasearch/detail-page';

      // Aggiungi la label del content type
      $variables['content_type_label'] = teasearch_get_content_type_label($content_type);

      // Processare icon se presente
      if (isset($schema['icon'])) {
        $variables['detail_icon'] = teasearch_render_icon($node, $schema['icon']);
      }

      // Processare fields
      if (isset($schema['fields'])) {
        $variables['detail_fields'] = teasearch_render_fields($node, $schema['fields']);
      }
    }
  }
}


/**
 * Renderizza l'icona secondo lo schema.
 */
function teasearch_render_icon($node, $icon_config)
{
  $field_name = $icon_config['field'] ?? NULL;
  $type = $icon_config['type'] ?? 'media_image';

  // ========================================================================
  // MODIFICA: Alcuni type non richiedono 'field' (es. square_or_main)
  // ========================================================================
  $types_without_field = [ 'square_or_main', 'bibliography_icon'];

  if (!$field_name && !in_array($type, $types_without_field)) {
    return NULL;
  }

  // Ottieni la funzione render per il type
  $render_function = teasearch_get_type_render_function($type);

  if (!function_exists($render_function)) {
    return NULL;
  }

  // Chiama la funzione render
  // Nota: $field_name può essere NULL per alcuni type
  $content = $render_function($node, $icon_config, $field_name);

  return $content;
}

/**
 * Renderizza i campi secondo lo schema.
 */
function teasearch_render_fields($node, $fields_config)
{
  $rendered_fields = [];
  $content_type = $node->bundle();
  
  foreach ($fields_config as $field_identifier => $field_config) {
    
    // Caso 1: Separatore (stringa semplice)
    if (is_string($field_config)) {
      $rendered_fields[$field_identifier] = [
        'type' => 'separator',
        'content' => $field_config, // es. "PROFILE"
        'label' => NULL,
        'wrapper_class' => 'separator',
      ];
      continue;
    }
    
    // Caso 2: Campo normale (array)
    // Inferisce o usa il type specificato
    $type = $field_config['type'] ?? teasearch_infer_field_type($node, $field_identifier);
    
    // Ottieni la funzione render per il type
    $render_function = teasearch_get_type_render_function($type);
    
    if (!function_exists($render_function)) {
      continue; // Salta questo campo se la funzione non esiste
    }
    
    // Chiama la funzione render
    $content = $render_function($node, $field_config, $field_identifier);
    
    // Se il contenuto è NULL o vuoto, salta il campo
    if ($content === NULL || $content === '') {
      continue;
    }
    
    // Ottiene la label (con traduzione)
    $label = teasearch_get_field_label($field_config, $field_identifier, $content_type);
    
    // Costruisce l'array strutturato
    $rendered_fields[$field_identifier] = [
      'type' => $type,
      'label' => $label,
      'content' => $content,
      'wrapper_class' => $field_config['wrapper_class'] ?? '',
    ];
  }
  
  return $rendered_fields;
}

