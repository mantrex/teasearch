{#
/**
 * @file
 * Template per listing taxonomy (/taxonomy/{vocabulary_id})
 */
#}

<article class="taxonomy-term taxonomy-term--detail taxonomy-wrapper">


	<div class="info-title-section">
		<div class='info-title-upper'>
			{{ 'Taxonomy' }}


		</div>
		<div class="container-fluid">
			<div class="info-title">
				{{ vocabulary_label }}
			</div>
		</div>
	</div>


	{# LISTA TERMINI #}
	<div class="detail-body">
		<div class="container-fluid">
			<div class="taxonomy-terms-listing">
				{% for term in taxonomy_terms %}
					<div class="taxonomy-term-item">
						<h3 class="term-name">
							<a href="{{ term.url }}">{{ term.name }}</a>
						</h3>
						{% if term.description %}
							<div class="term-description">
								{{ term.description|striptags }}
							</div>
						{% endif %}
					</div>
				{% endfor %}
			</div>
		</div>
	</div>

</article>
