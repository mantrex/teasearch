{{ attach_library('teasearch/menu-keyboard') }}

{% import _self as menus %}
{% macro menu_links(items, attributes, menu_level) %}
	{% if items %}
		<ul{{attributes.addClass(menu_level==0?'navbar-nav':'dropdown-menu')}}>
			{% for item in items %}
				{%
          set link_classes = [
            menu_level == 0 ? 'nav-link px-3' : 'dropdown-item',
            item.in_active_trail ? 'active',
            item.below ? 'dropdown-toggle' : ''
          ]
        %}

				{# Attributi per dropdown accessibile #}
				{% set link_attributes = {
          'class': link_classes
        } %}

				{% if item.below %}
					{% set link_attributes = link_attributes|merge({
            'data-bs-toggle': 'dropdown',
            'role': 'button',
            'aria-expanded': 'false',
            'tabindex': '0'
          }) %}
				{% endif %}

				<li{{item.attributes.addClass('nav-item',item.below?'dropdown':'')}}>
					{{ link(item.title, item.url, link_attributes) }}
					{% if item.below %}
						{{ menus.menu_links(item.below, attributes.removeClass('navbar-nav'), menu_level + 1) }}
					{% endif %}
				</li>
			{% endfor %}
		</ul>
	{% endif %}
{% endmacro %}

{{ menus.menu_links(items, attributes, 0) }}
