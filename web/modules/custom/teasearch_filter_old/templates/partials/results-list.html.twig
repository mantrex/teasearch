{#
  /**
  * @file
  * Results list template - Adapted for carousel-view-all layout
  */
#}

<div class="results-list">
  {% for entity in entities %}
    {% set entity_config = content_type_config.results %}
    {% set main_field = entity_config.mainfield|default('title') %}
    {% set sub_field = entity_config.subfield %}
    {% set image_field = entity_config.image %}
    {% set alt_image_field = entity_config.altimage %}
    {% set image_format = entity_config.image_format|default('square') %}

    {# Link wrapper per tutto l'elemento #}
    {% if entity_type == 'user' %}
      {% set entity_url = path('entity.user.canonical', {'user': entity.uid.value}) %}
    {% else %}
      {% set entity_url = path('entity.node.canonical', {'node': entity.nid.value}) %}
    {% endif %}

    <a href="{{ entity_url }}" class="result-item">

      {# IMMAGINE - Sezione fissa a sinistra #}
      <div class="result-item-image">
        {% if image_field %}
          {% include 'modules/custom/teasearch_filter/templates/partials/entity-image.html.twig' with {
						'entity': entity,
						'entity_type': entity_type,
						'image_field': image_field,
						'image_format': image_format,
						'module_path': module_path
					} %}
        {% else %}
          {# Immagine di default se non presente #}
          <div class="item-image">
            {% if entity_type == 'user' %}
              <img
              src="{{ module_path }}/images/default-avatar.png" alt="{{ entity.label }}" class="entity-image" loading="lazy">
                {% else %}
                <img src="{{ module_path }}/images/default.png" alt="{{ entity.label }}" class="entity-image" loading="lazy">
                {% endif %}
              </div>
            {% endif %}
          </div>

          {# CONTENUTO - Sezione principale a destra #}
          <div class="result-item-content">

            {# Titolo #}
            <h3 class="result-item-title">
              {{ entity.label }}
            </h3>

            {# Descrizione/sommario #}
            {% if sub_field %}
              {% set field_data = attribute(entity, sub_field) %}
              {% if field_data and field_data.0 %}
                <div class="result-item-description">
                  {% set description = null %}

                  {# Priority 1: Use processed content from fallback system #}
                  {% if entity.teasearch_processed_content %}
                    {% set description = entity.teasearch_processed_content %}

                  {# Priority 2: Fallback to old system for compatibility #}
                    {% elseif sub_field %}
                    {% set field_data = attribute(entity, sub_field) %}
                    {% if field_data and field_data.0 %}
                      {# Gestione diversi tipi di campo per la descrizione #}
                      {% if field_data.0.summary %}
                        {% set description = field_data.0.summary %}
                      {% elseif field_data.0.value %}
                        {% set description = field_data.0.value %}
                      {% elseif field_data.value %}
                        {% set description = field_data.value %}
                      {% endif %}
                    {% endif %}
                  {% endif %}

                  {% if description %}
                    {{ description|striptags|slice(0, 200) }}
                    {% if description|length > 200 %}
                      …
                    {% endif %}
                  {% endif %}
                </div>
              {% endif %}
            {% endif %}

            {# Metadati - nella parte inferiore #}
            <div class="result-item-meta">
              {% if entity.created and entity.created.value %}
                <span class="result-item-date">
                  {{ entity.created.value|format_date('medium') }}
                </span>
              {% endif %}

              {% if entity.type and entity.type.entity %}
                <span class="result-item-type">
                  {{ entity.type.entity.label }}
                </span>
              {% endif %}
            </div>

          </div>
        </a>
      {% endfor %}
    </div>
    