{#
  /**
  * @file
  * Entity image partial template con supporto fallback altimage.
  *
  * Variables:
  * - entity: The entity object
  * - entity_type: Entity type (node/user)
  * - image_field: Field machine name for the image
  * - alt_image_field: Fallback image field
  * - image_format: Image format (rounded/square)
  * - module_path: Module path for default images
  */
#}

<div class="item-image">
  {% set image_url = null %}
  {% set current_image_field = null %}

  {# Gestione immagini per utenti #}
  {% if entity_type == 'user' %}
    {% if image_field == 'user_picture' and entity.user_picture.0 %}
      {% if entity.user_picture.0.entity and entity.user_picture.0.entity.fileuri %}
        {% set image_url = file_url(entity.user_picture.0.entity.fileuri) %}
        {% set current_image_field = 'user_picture' %}
      {% endif %}
    {% else %}
      {# Per altri campi immagine degli utenti, usa accesso dinamico #}
      {% set field_data = attribute(entity, image_field) %}
      {% if field_data and field_data.0 %}
        {% if field_data.0.entity and field_data.0.entity.fileuri %}
          {% set image_url = file_url(field_data.0.entity.fileuri) %}
          {% set current_image_field = image_field %}
        {% elseif field_data.0.uri %}
          {% set image_url = file_url(field_data.0.uri) %}
          {% set current_image_field = image_field %}
        {% endif %}
      {% endif %}
    {% endif %}
  {% else %}
    {# Gestione immagini per nodi - prova prima image_field #}
    {% set field_data = attribute(entity, image_field) %}
    {% if field_data and field_data.0 %}
      {# Approccio 1: entity.fileuri (più comune per campi immagine) #}
      {% if field_data.0.entity and field_data.0.entity.fileuri %}
        {% set image_url = file_url(field_data.0.entity.fileuri) %}
        {% set current_image_field = image_field %}

      {# Approccio 2: preprocess hook result (per campi con target_id) #}
        {% elseif entity.teasearch_image_url %}
        {% set image_url = entity.teasearch_image_url %}
        {% set current_image_field = image_field %}

      {# Approccio 3: uri diretto (per alcuni tipi di campo) #}
        {% elseif field_data.0.uri %}
        {% set image_url = file_url(field_data.0.uri) %}
        {% set current_image_field = image_field %}
      {% endif %}
    {% endif %}

    {# FALLBACK: Se image_field non ha prodotto risultati, prova alt_image_field #}
    {% if not image_url and alt_image_field %}
      {% set alt_field_data = attribute(entity, alt_image_field) %}
      {% if alt_field_data and alt_field_data.0 %}
        {% if alt_field_data.0.entity and alt_field_data.0.entity.fileuri %}
          {% set image_url = file_url(alt_field_data.0.entity.fileuri) %}
          {% set current_image_field = alt_image_field %}
        {% elseif entity.teasearch_alt_image_url %}
          {% set image_url = entity.teasearch_alt_image_url %}
          {% set current_image_field = alt_image_field %}
        {% elseif alt_field_data.0.uri %}
          {% set image_url = file_url(alt_field_data.0.uri) %}
          {% set current_image_field = alt_image_field %}
        {% endif %}
      {% endif %}
    {% endif %}
  {% endif %}

  {# Fallback finale: immagine di default appropriata #}
  {% if not image_url %}
    {% if entity_type == 'user' %}
      {% set image_url = module_path ~ '/images/default-avatar.png' %}
    {% else %}
      {% set image_url = module_path ~ '/images/default.png' %}
    {% endif %}
    {% set current_image_field = 'default' %}
  {% endif %}

  {# Rendering dell'immagine con debug info #}
  <img src="{{ image_url }}" alt="{{ entity.label }}" class="entity-image {{ image_format == 'rounded' ? 'rounded-circle' : 'rounded' }}" width="64" height="64" loading="lazy" onerror="this.src='{{ module_path }}/images/placeholder.png'; this.onerror=null;" data-field-used="{{ current_image_field }}" title="Using: {{ current_image_field }}"></div>
  