{#
  /**
  * @file
  * Date selector filter partial template (manual year inputs).
  *
  * Variables:
  * - content_type: Current content type
  * - date_data: Date configuration and data
  */
#}

{% if date_data and date_data.enabled %}
  <details class="filter-group date-filter" data-name="date_selector">
    <summary class="filter-title">
      {{ 'Date Range'|t }}
      {% if date_data.selected_from or date_data.selected_to %}
        <span class="filter-badge">
          1
        </span>
      {% endif %}
    </summary>

    <div class="filter-content">
      <div class="date-selector-container">

        <div class="year-inputs">
          <div class="year-input-group">
            <label for="date_year_from" class="form-label">
              {{ 'From Year'|t }}
            </label>
            <input type="number" id="date_year_from" name="year_from" class="form-control" value="{{ date_data.selected_from|default('') }}" min="{{ date_data.min_year }}" max="{{ date_data.max_year }}" placeholder="{{ 'e.g. -500'|t }}">
              <small class="form-text text-muted">
                {{ 'Range: %min to %max (Negative = BC, Positive = CE)'|t({'%min': date_data.min_year, '%max': date_data.max_year}) }}
              </small>
            </div>

            <div class="year-input-group">
              <label for="date_year_to" class="form-label">
                {{ 'To Year'|t }}
              </label>
              <input type="number" id="date_year_to" name="year_to" class="form-control" value="{{ date_data.selected_to|default('') }}" min="{{ date_data.min_year }}" max="{{ date_data.max_year }}" placeholder="{{ 'e.g. 500'|t }}">
                <small class="form-text text-muted">
                  {{ 'Range: %min to %max (Negative = BC, Positive = CE)'|t({'%min': date_data.min_year, '%max': date_data.max_year}) }}
                </small>
              </div>
            </div>

            <div class="date-actions">
              <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearDateRange()">
                {{ 'Clear dates'|t }}
              </button>
              <button type="button" class="btn btn-sm btn-outline-info" onclick="setCommonRanges()">
                {{ 'Common ranges'|t }}
              </button>
            </div>

            {# Quick preset buttons (optional) #}
            <div class="date-presets" style="display: none;" id="date-presets">
              <div class="preset-buttons">
                <button type="button" class="btn btn-sm btn-light" onclick="setPreset(-3000, -1000)">
                  Ancient Times
                </button>
                <button type="button" class="btn btn-sm btn-light" onclick="setPreset(-800, 500)">
                  Classical Period
                </button>
                <button type="button" class="btn btn-sm btn-light" onclick="setPreset(500, 1500)">
                  Medieval
                </button>
                <button type="button" class="btn btn-sm btn-light" onclick="setPreset(1400, 1800)">
                  Renaissance-Modern
                </button>
                <button type="button" class="btn btn-sm btn-light" onclick="setPreset(1800, {{ date('Y') }})">
                  Contemporary
                </button>
              </div>
            </div>
          </div>
        </div>
      </details>

      {# JavaScript for date selector functionality #}
      <script>
		function clearDateRange() {
			document.getElementById('date_year_from').value = '';
			document.getElementById('date_year_to').value = '';
		}

		function setCommonRanges() {
			const presets = document.getElementById('date-presets');
			if (presets.style.display === 'none') {
				presets.style.display = 'block';
			} else {
				presets.style.display = 'none';
			}
		}

		function setPreset(fromYear, toYear) {
			document.getElementById('date_year_from').value = fromYear;
			document.getElementById('date_year_to').value = toYear;
			
			// Hide presets
			document.getElementById('date-presets').style.display = 'none';
		}

		// Validate date range
		document.addEventListener('DOMContentLoaded', function() {
			const fromInput = document.getElementById('date_year_from');
			const toInput = document.getElementById('date_year_to');

			function validateRange() {
				const fromValue = parseInt(fromInput.value);
				const toValue = parseInt(toInput.value);

				if (fromValue && toValue && fromValue > toValue) {
					fromInput.setCustomValidity('From year must be less than or equal to To year');
					toInput.setCustomValidity('To year must be greater than or equal to From year');
				} else {
					fromInput.setCustomValidity('');
					toInput.setCustomValidity('');
				}
			}

			fromInput.addEventListener('input', validateRange);
			toInput.addEventListener('input', validateRange);
		});
	</script>

      {# CSS for date selector styling #}
      <style>
		.date-filter {
			margin: 1rem 0;
		}

		.date-filter summary {
			cursor: pointer;
			padding: 0.75rem;
			background: var(--filter-item, #e9ecef);
			border-radius: 4px;
			user-select: none;
		}

		.filter-badge {
			background: #007bff;
			color: white;
			border-radius: 50%;
			padding: 0.2rem 0.5rem;
			font-size: 0.8rem;
			margin-left: 0.5rem;
		}

		.date-selector-container {
			padding: 1rem;
			background: #f8f9fa;
			border: 1px solid #dee2e6;
			border-top: none;
		}

		.year-inputs {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1rem;
			margin-bottom: 1rem;
		}

		.year-input-group {
			display: flex;
			flex-direction: column;
		}

		.form-label {
			margin-bottom: 0.5rem;
			font-weight: 600;
			color: #495057;
			font-size: 0.9rem;
		}

		.form-control {
			padding: 0.5rem;
			border: 1px solid #ced4da;
			border-radius: 4px;
			font-size: 0.9rem;
			background: white;
		}

		.form-control:focus {
			border-color: #007bff;
			outline: none;
			box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
		}

		.form-control:invalid {
			border-color: #dc3545;
		}

		.form-text {
			margin-top: 0.25rem;
			font-size: 0.75rem;
			color: #6c757d;
		}

		.date-actions {
			display: flex;
			gap: 0.5rem;
			justify-content: center;
			margin-bottom: 1rem;
		}

		.date-presets {
			background: white;
			border-radius: 4px;
			border: 1px solid #dee2e6;
			padding: 1rem;
		}

		.preset-buttons {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			justify-content: center;
		}

		.preset-buttons .btn {
			font-size: 0.8rem;
			padding: 0.25rem 0.5rem;
		}

		@media(max-width: 768px) {
			.year-inputs {
				grid-template-columns: 1fr;
			}
			
			.date-actions {
				flex-direction: column;
			}
			
			.preset-buttons {
				flex-direction: column;
			}
		}
	</style>
    {% endif %}
    