{#
	/**
	* @file
	* Century/Year range filter con SELECT invece di timeline.
	*
	* Variables:
	* - content_type: Current content type
	* - century_data: Century configuration and data
	*/
#}

{% if century_data and century_data.enabled %}
	<details	class="filter-group century-filter"	data-name="century_selector">
		<summary	class="filter-title">
			{{ 'Century Range'|t }}
			{% if century_data.selected_from or century_data.selected_to %}
				<span	class="filter-badge">
					1
				</span>
			{% endif %}
		</summary>

		<div	class="filter-content">
			<div	class="century-selector-container">

				{# Century Selection Mode (default) #}
				<div	class="century-selects"	id="century-selects">
					<div	class="century-select-group">
						<label	for="century_from"	class="form-label">
							{{ 'Start'|t }}
						</label>
						<select	id="century_from"	name="century_from"	class="form-control century-select">
							<option	value="">
								{{ 'Select century...'|t }}
							</option>
							{% for century in century_data.century_options %}
								<option	value="{{ century.start_year }}"	{{ century_data.selected_from == century.start_year ? 'selected' : '' }}>
									{{ century.label }}
								</option>
							{% endfor %}
						</select>
					</div>

					<div	class="century-select-group">
						<label	for="century_to"	class="form-label">
							{{ 'End'|t }}
						</label>
						<select	id="century_to"	name="century_to"	class="form-control century-select">
							<option	value="">
								{{ 'Select century...'|t }}
							</option>
							{% for century in century_data.century_options %}
								<option	value="{{ century.end_year }}"	{{ century_data.selected_to == century.end_year ? 'selected' : '' }}>
									{{ century.label }}
								</option>
							{% endfor %}
						</select>
					</div>
				</div>

				{# Detailed Year Input (hidden by default) #}
				<div	class="year-details"	id="year-details"	style="display: none;">
					<div	class="year-inputs">
						<div	class="year-input-group">
							<label	for="year_from_manual"	class="form-label">
								{{ 'From Year'|t }}
							</label>
							<input	type="number"	id="year_from_manual"	name="year_from_manual"	class="form-control"	value="{{ century_data.selected_from|default('') }}"	placeholder="{{ 'e.g. -500'|t }}">
								<small	class="form-text text-muted">
									{{ 'Negative = BC, Positive = CE'|t }}
								</small>
							</div>
							<div	class="year-input-group">
								<label	for="year_to_manual"	class="form-label">
									{{ 'To Year'|t }}
								</label>
								<input	type="number"	id="year_to_manual"	name="year_to_manual"	class="form-control"	value="{{ century_data.selected_to|default('') }}"	placeholder="{{ 'e.g. 500'|t }}">
									<small	class="form-text text-muted">
										{{ 'Negative = BC, Positive = CE'|t }}
									</small>
								</div>
							</div>
						</div>

						{# Toggle Link #}
						<div	class="century-toggle">
							<a	href="#"	id="toggle-details"	onclick="toggleCenturyMode(event)">
								{{ 'set details'|t }}
							</a>
						</div>

						{# Hidden inputs for form submission #}
						<input	type="hidden"	id="hidden_year_from"	name="year_from"	value="{{ century_data.selected_from|default('') }}">
							<input	type="hidden"	id="hidden_year_to"	name="year_to"	value="{{ century_data.selected_to|default('') }}"></div>
						</div>
					</details>

					{# JavaScript for century selector functionality - FIXED #}
					<script>
		let isDetailsMode = false;

		function toggleCenturyMode(event) {
			event.preventDefault();
			
			const centurySelects = document.getElementById('century-selects');
			const yearDetails = document.getElementById('year-details');
			const toggleLink = document.getElementById('toggle-details');
			
			if (!centurySelects || !yearDetails || !toggleLink) {
				console.error('Century selector elements not found');
				return;
			}
			
			if (isDetailsMode) {
				// Switch back to century mode
				centurySelects.style.display = 'block';
				yearDetails.style.display = 'none';
				toggleLink.textContent = '{{ 'set details'|t }}';
				isDetailsMode = false;
				
				// Update hidden inputs from selects
				updateFromCenturySelects();
			} else {
				// Switch to details mode
				centurySelects.style.display = 'none';
				yearDetails.style.display = 'block';
				toggleLink.textContent = '{{ 'back to centuries'|t }}';
				isDetailsMode = true;
				
				// Sync manual inputs with current hidden values
				const hiddenFrom = document.getElementById('hidden_year_from');
				const hiddenTo = document.getElementById('hidden_year_to');
				const manualFrom = document.getElementById('year_from_manual');
				const manualTo = document.getElementById('year_to_manual');
				
				if (hiddenFrom && manualFrom) {
					manualFrom.value = hiddenFrom.value || '';
				}
				if (hiddenTo && manualTo) {
					manualTo.value = hiddenTo.value || '';
				}
			}
		}

		function updateFromCenturySelects() {
			const centuryFromSelect = document.getElementById('century_from');
			const centuryToSelect = document.getElementById('century_to');
			const hiddenFrom = document.getElementById('hidden_year_from');
			const hiddenTo = document.getElementById('hidden_year_to');
			
			if (centuryFromSelect && hiddenFrom) {
				hiddenFrom.value = centuryFromSelect.value || '';
			}
			if (centuryToSelect && hiddenTo) {
				hiddenTo.value = centuryToSelect.value || '';
			}
		}

		function updateFromManualInputs() {
			const manualFrom = document.getElementById('year_from_manual');
			const manualTo = document.getElementById('year_to_manual');
			const hiddenFrom = document.getElementById('hidden_year_from');
			const hiddenTo = document.getElementById('hidden_year_to');
			
			if (manualFrom && hiddenFrom) {
				hiddenFrom.value = manualFrom.value || '';
			}
			if (manualTo && hiddenTo) {
				hiddenTo.value = manualTo.value || '';
			}
		}

		// Event listeners - Initialize when DOM is ready
		document.addEventListener('DOMContentLoaded', function() {
			// Century selects change
			const centuryFromSelect = document.getElementById('century_from');
			const centuryToSelect = document.getElementById('century_to');
			const manualFrom = document.getElementById('year_from_manual');
			const manualTo = document.getElementById('year_to_manual');
			
			if (centuryFromSelect) {
				centuryFromSelect.addEventListener('change', updateFromCenturySelects);
			}
			if (centuryToSelect) {
				centuryToSelect.addEventListener('change', updateFromCenturySelects);
			}
			
			// Manual inputs change
			if (manualFrom) {
				manualFrom.addEventListener('input', updateFromManualInputs);
			}
			if (manualTo) {
				manualTo.addEventListener('input', updateFromManualInputs);
			}
			
			// Initialize hidden inputs with current select values
			updateFromCenturySelects();
		});
	</script>

				{% endif %}
				