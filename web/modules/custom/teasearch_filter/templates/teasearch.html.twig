{#
  /**
  * @file
  * Teasearch filter page template.
  *
  * Variables:
  * - filter_form: Filter form render array
  * - entities: Array of loaded entities (nodes or users)
  * - content_type_config: Complete content type configuration
  * - entity_type: Entity type (node or user)
  * - total_results: Total number of results
  * - has_filters: Whether there are active filters
  * - grouped_filters: Prepared filters for display
  * - century_data: Century selector configuration
  * - date_data: Date selector configuration
  */
#}

<div class="teasearch-wrapper {% if mixed_content_types %}teasearch-no-sidebar{% endif %}">

  {# Sidebar with filters - NASCOSTA se mixed_content_types #}
  {% if not mixed_content_types %}
    <aside class="teasearch-sidebar">
      {% if grouped_filters %}
        {% include 'modules/custom/teasearch_filter/templates/partials/filter-form.html.twig' with {
          'grouped_filters': grouped_filters,
          'content_type': content_type,
          'century_data': century_data,
          'date_data': date_data
        } %}
      {% else %}
        {{ filter_form }}
      {% endif %}
    </aside>
  {% endif %}

  {# Main results area #}
  <main class="teasearch-results {% if mixed_content_types %}teasearch-results-full{% endif %}">

    {# Search info header per ricerca all #}
    {% if mixed_content_types and search_query %}
      <div class="search-info-header">
        <h1 class="search-results-title">
          {{ 'Search Results'|t }}
          {% if total_results %}
            <span class="results-count">
              (
              {{ total_results }}
              )
            </span>
          {% endif %}
        </h1>
        <div class="search-meta">
          <span class="search-query-display">
            {{ 'Search term:'|t }}
            <strong>
              "
              {{ search_query }}
              "
            </strong>
          </span>
        </div>
      </div>
    {% endif %}

    {% if entities %}
      {% if not mixed_content_types %}
        {% include 'modules/custom/teasearch_filter/templates/partials/results-header.html.twig' %}
      {% endif %}

      {% include 'modules/custom/teasearch_filter/templates/partials/results-list.html.twig' %}

      {# Paginator #}
      {% if paginator_data %}
        {% include 'modules/custom/teasearch_filter/templates/partials/paginator.html.twig' with {
          'paginator_data': paginator_data,
          'content_type': content_type,
          'current_query': current_query,
          'is_free_search': is_free_search|default(false)
        } %}
      {% endif %}

    {% else %}
      {% include 'modules/custom/teasearch_filter/templates/partials/no-results.html.twig' %}
    {% endif %}
  </main>
</div>


