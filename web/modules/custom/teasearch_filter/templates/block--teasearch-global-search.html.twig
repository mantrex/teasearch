{#
  /**
  * @file
  * Template for Teasearch Global Search Block.
  *
  * Available variables:
  * - content_type_options: Array of content type options for dropdown.
  * - search_action: URL for form submission.
  * - current_query: Current search query (if any).
  * - current_content_type: Currently selected content type.
  */
#}

<div class="teasearch-global-search-block">
	<form action="{{ search_action }}" method="get" class="global-search-form">
		<div
			class="search-input-wrapper">
			{# Search input #}
			<input
			type="text" name="q" class="form-control search-input" placeholder="{{ 'Search for...'|t }}" value="{{ current_query }}" required>

			{# Content type selector #}
			<div class="content-type-selector">
				<span class="selector-prefix"></span>
				<select name="content_type" class="form-select content-type-dropdown">
					{% for value, label in content_type_options %}
						<option value="{{ value }}" {% if value == current_content_type %} selected {% endif %}>
							{{ label }}
						</option>
					{% endfor %}
				</select>
			</div>

			{# Search button #}
			<button type="submit" class="btn btn-primary search-button">
				<span class="search-icon">
<img style='width:40px' src="{{ file_url(directory ~ '/images/search_lens.svg') }}">


				</span>
			</button>
		</div>
	</form>
</div>

<style>
	.teasearch-global-search-block {
		width: 100%;
		max-width: 900px;
		margin: 0 auto;
	}

	.global-search-form {
		width: 100%;
	}

	.search-input-wrapper {
		display: flex;
		align-items: center;
		background: var(--light);
		border: 2px solid var(--light-border);
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 2px 4px var(--box-shadow);
	}

	.search-input {
		flex: 1;
		border: none;
		padding: 12px 16px;
		font-size: 1rem;
		outline: none;
		color: var(--body-text);
	}

	.search-input:focus {
		outline: none;
		box-shadow: none;
	}

	.search-input::placeholder {
		color: var(--light-text);
	}

	.content-type-selector {
		display: flex;
		align-items: center;
		padding: 0 12px;
		border-left: 1px solid var(--light-border);
		border-right: 1px solid var(--light-border);

	}

	.selector-prefix {
		font-size: 1rem;
		color: var(--light-text);
		margin-right: 8px;
	}

	.content-type-dropdown {
		border: none;
		background: transparent;
		padding: 8px 12px;
		font-size: 0.95rem;
		cursor: pointer;
		outline: none;
		min-width: 120px;
		color: var(--body-text);
	}

	.content-type-dropdown:focus {
		outline: none;
		box-shadow: none;
	}

	.search-button {
		border: none;
		background: var(--light);
		color: var(--light);
		padding: 12px 24px;
		cursor: pointer;
		transition: background 0.3s ease;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.search-button:hover {
		background: var(--search-button-hover);
		color: white;
	}
	.search-button:active {
		background: var(--search-button-active) !important;
		color: white;
	}


	.search-icon {
		font-size: 1.2rem;
	}

	/* Responsive */
	@media(max-width: 768px) {
		.search-input-wrapper {
			flex-wrap: wrap;
		}

		.content-type-selector {
			order: 3;
			width: 100%;
			border-left: none;
			border-right: none;
			border-top: 1px solid var(--light-border);
			justify-content: center;
		}

		.search-button {
			width: auto;
		}
	}
</style>
